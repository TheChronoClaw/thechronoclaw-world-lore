"""
OpenClaw + LangGraph Adaptive Heartbeat Monitor
- Real Grok API with retries
- Telegram + Slack dual alerts on anomaly
- Full LangSmith tracing (just set env vars)
- Adaptive frequency: 10min normal → 1min high on anomaly
- Persistent checkpoint + detailed logging
"""

import os
import logging
from datetime import datetime, timedelta
from typing import TypedDict, Literal
import requests
from tenacity import retry, stop_after_attempt, wait_exponential, retry_if_exception_type
from langgraph.graph import StateGraph, END
from langgraph.checkpoint.sqlite import SqliteSaver

# ==================== CONFIG ====================
XAI_API_KEY = os.getenv("XAI_API_KEY")
TELEGRAM_BOT_TOKEN = os.getenv("TELEGRAM_BOT_TOKEN", "")
TELEGRAM_CHAT_ID = os.getenv("TELEGRAM_CHAT_ID", "")
SLACK_WEBHOOK_URL = os.getenv("SLACK_WEBHOOK_URL", "")

# LangSmith (zero-code integration - just set these env vars)
# export LANGCHAIN_TRACING_V2="true"
# export LANGCHAIN_API_KEY="lsv2_xxx..."
# export LANGCHAIN_PROJECT="openclaw-heartbeat"

if not XAI_API_KEY:
    raise ValueError("XAI_API_KEY not set")

XAI_API_URL = "https://api.x.ai/v1/chat/completions"
GROK_MODEL = "grok-4.2"

# ==================== LOGGING ====================
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s [%(levelname)s] %(message)s",
    handlers=[
        logging.FileHandler("openclaw_heartbeat.log"),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger("HeartbeatMonitor")

# ==================== STATE ====================
class HeartbeatState(TypedDict):
    timestamp: str
    mode: Literal["normal", "high_frequency"]
    status: Literal["normal", "anomaly"]
    event_id: str | None
    description: str | None
    grok_response: str | None
    analysis_result: str | None
    high_freq_end_time: str | None
    consecutive_anomalies: int

# ==================== GROK API with RETRY ====================
@retry(
    stop=stop_after_attempt(3),
    wait=wait_exponential(multiplier=1, min=2, max=10),
    retry=retry_if_exception_type((requests.exceptions.RequestException,)),
    reraise=True
)
def call_grok(prompt: str, max_tokens: int = 200) -> str:
    headers = {
        "Authorization": f"Bearer {XAI_API_KEY}",
        "Content-Type": "application/json"
    }
    payload = {
        "model": GROK_MODEL,
        "messages": [{"role": "user", "content": prompt}],
        "temperature": 0.5,
        "max_tokens": max_tokens
    }
    response = requests.post(XAI_API_URL, headers=headers, json=payload, timeout=15)
    response.raise_for_status()
    content = response.json()["choices"][0]["message"]["content"].strip()
    logger.info(f"Grok call success: {content[:100]}...")
    return content

# ==================== ALERTS ====================
def send_telegram_alert(message: str):
    if not TELEGRAM_BOT_TOKEN or not TELEGRAM_CHAT_ID:
        logger.warning("Telegram not configured")
        return
    url = f"https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/sendMessage"
    payload = {"chat_id": TELEGRAM_CHAT_ID, "text": message, "parse_mode": "Markdown"}
    try:
        requests.post(url, json=payload, timeout=5).raise_for_status()
        logger.info("Telegram alert sent")
    except Exception as e:
        logger.error(f"Telegram failed: {e}")

def send_slack_alert(message: str):
    if not SLACK_WEBHOOK_URL:
        logger.warning("Slack not configured")
        return
    payload = {"text": message}
    try:
        requests.post(SLACK_WEBHOOK_URL, json=payload, timeout=5).raise_for_status()
        logger.info("Slack alert sent")
    except Exception as e:
        logger.error(f"Slack failed: {e}")

# ==================== NODES ====================
def check_heartbeat(state: HeartbeatState) -> HeartbeatState:
    now = datetime.now()
    now_iso = now.isoformat()
    logger.info("Heartbeat check started")

    prompt = (
        "Quick scan: Any major global news or X hotspots in the last 10 minutes? "
        "Reply ONLY with NORMAL or ANOMALY: [short description, max 20 words]"
    )
    
    try:
        grok_scan = call_grok(prompt, max_tokens=80)
    except Exception as e:
        logger.error(f"Grok scan failed: {e}")
        grok_scan = "NORMAL"  # fail-safe

    if "ANOMALY:" in grok_scan.upper():
        desc = grok_scan.split(":", 1)[1].strip() if ":" in grok_scan else "Unknown"
        logger.warning(f"ANOMALY: {desc}")
        return {
            "timestamp": now_iso,
            "status": "anomaly",
            "event_id": f"E-{now.strftime('%Y%m%d-%H%M')}",
            "description": desc,
            "high_freq_end_time": (now + timedelta(minutes=30)).isoformat(),
            "consecutive_anomalies": state["consecutive_anomalies"] + 1
        }
    else:
        logger.info("No anomaly")
        return {
            "timestamp": now_iso,
            "status": "normal",
            "event_id": None,
            "description": None,
            "consecutive_anomalies": 0
        }

def decide_frequency(state: HeartbeatState) -> HeartbeatState:
    now = datetime.fromisoformat(state["timestamp"])
    
    if state["mode"] == "high_frequency":
        if state["high_freq_end_time"]:
            end = datetime.fromisoformat(state["high_freq_end_time"])
            if now >= end or state["consecutive_anomalies"] == 0:
                logger.info("Back to normal frequency")
                return {**state, "mode": "normal", "high_freq_end_time": None}
    
    if state["status"] == "anomaly":
        logger.info("Entering high frequency mode")
        return {**state, "mode": "high_frequency"}
    
    return state

def report_and_analyze(state: HeartbeatState) -> HeartbeatState:
    if state["status"] != "anomaly":
        return state
    
    alert_msg = (
        f"🚨 *OpenClaw Heartbeat Alert*\n"
        f"Event: {state['event_id']}\n"
        f"Time: {state['timestamp']}\n"
        f"Description: {state['description']}"
    )
    
    send_telegram_alert(alert_msg)
    send_slack_alert(alert_msg)
    
    prompt = (
        f"URGENT EVENT: {state['description']}\n"
        "Quick summary. Reply ONLY with: ANALYSIS COMPLETE or ACTION REQUIRED"
    )
    try:
        grok_reply = call_grok(prompt, max_tokens=60)
    except Exception as e:
        grok_reply = f"Analysis failed: {str(e)}"
        logger.error(grok_reply)
    
    return {
        **state,
        "grok_response": grok_reply,
        "analysis_result": "Processed"
    }

def final_log(state: HeartbeatState) -> HeartbeatState:
    status = state["status"].upper()
    event = state.get("event_id", "N/A")
    logger.info(f"Heartbeat {event} → {status}")
    return state

# ==================== BUILD GRAPH ====================
workflow = StateGraph(HeartbeatState)

workflow.add_node("check", check_heartbeat)
workflow.add_node("decide_freq", decide_frequency)
workflow.add_node("report_analyze", report_and_analyze)
workflow.add_node("log", final_log)

workflow.set_entry_point("check")
workflow.add_edge("check", "decide_freq")
workflow.add_edge("decide_freq", "report_analyze")
workflow.add_edge("report_analyze", "log")
workflow.add_edge("log", END)

# Persistence
memory = SqliteSaver.from_conn_string("openclaw_heartbeat.db")
app = workflow.compile(checkpointer=memory)

# ==================== RUN EXAMPLE ====================
if __name__ == "__main__":
    config = {"configurable": {"thread_id": "claw-heartbeat-v6"}}
    
    initial = {
        "timestamp": datetime.now().isoformat(),
        "mode": "normal",
        "status": "normal",
        "consecutive_anomalies": 0
    }
    
